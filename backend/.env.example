# ============================================================
# Riverty Contract Review — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- DEMO MODE (active by default) ---
OPENAI_API_KEY=your_openai_api_key_here
APP_ENV=development
LOG_LEVEL=INFO
CHROMA_PERSIST_PATH=./chroma_db
UPLOAD_DIR=./uploads
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# --- PRODUCTION MODE (uncomment when migrating to Azure) ---
# See docs/azure-services.md for how to get these values
# See .claude/skills/swap-to-azure.md for migration steps

# Azure OpenAI (replaces plain OpenAI)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Azure AI Search (replaces ChromaDB)
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_KEY=
# AZURE_SEARCH_INDEX_NAME=riverty-contracts

# Azure Blob Storage (replaces local filesystem)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=contracts

# Azure Document Intelligence (replaces PyMuPDF + Tesseract)
# AZURE_DOC_INTELLIGENCE_ENDPOINT=
# AZURE_DOC_INTELLIGENCE_KEY=
